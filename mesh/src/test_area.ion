enum Shape:
    Circle(Float)
    Rect(Float, Float)
    Line

enum Result[T,U]:
    Ok(T)
    Err(U)

fn area(s Shape) -> Result[Float, String]:
    match s:
        :Circle(r) =>
            println("Calculating area of circle with radius", r)
            :Ok(r * r)
        :Rect(w, h) => :Ok(w * h)
        _ => :Err("Unsupported shape")

fn proc():
    println("inside proc")
    const dat = receive()
    println("proc recievd", dat)

const v = proc
debug(v)
const p = spawn v()
const r = :Circle(3.5)
debug(r)
const a = area(r)
debug(a)
send(p, "hello")
